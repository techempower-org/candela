# Handbook assets are generated by scripts/build-handbook-assets.py with LF
# line endings and parsed by blank-line paragraph splits at runtime. Pin them to
# LF so a Windows / core.autocrlf checkout can't rewrite them to CRLF and break
# chaptering (defense-in-depth alongside the CRLF normalize in CandelaHandbookSource).
source-handbook/src/main/assets/** text eol=lf
