<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- #1238 — all Google News traffic is HTTPS to news.google.com
         (the public RSS endpoints). No special permissions beyond
         INTERNET; ACCESS_NETWORK_STATE declared for symmetry with the
         other source modules in the roster. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

</manifest>
