<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup rules.

  Issue #951 — Exclude the EncryptedSharedPreferences file from BOTH
  cloud-backup AND device-transfer. The actual file is `storyvox.secrets`
  (see DataModule.provideEncryptedPrefs). Prior versions excluded
  `storyvox_secure_prefs`, a stale name that never matched anything, so
  encrypted blobs were being restored onto a fresh install whose Android
  Keystore could not verify them — crashing on cold start with
  `KeyStoreException: Signature/MAC verification failed`.

  Defense in depth: DataModule also catches keystore/MAC failures on
  read and wipes + regenerates the prefs file.

  Cloud backup: include everything except encrypted secrets.
  Device transfer: include everything except encrypted secrets.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="storyvox.secrets.xml" />
        <exclude domain="sharedpref" path="storyvox.secrets" />
        <!-- #1514 — encrypted document wallet: never cloud-backed-up. -->
        <exclude domain="file" path="wallet/" />
        <!-- Issue #1515 — deadline reminders are on-device only (privacy.md §2.11). -->
        <exclude domain="file" path="deadline_reminders.json" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="storyvox.secrets.xml" />
        <exclude domain="sharedpref" path="storyvox.secrets" />
        <!-- #1514 — encrypted document wallet: never device-transferred. -->
        <exclude domain="file" path="wallet/" />
        <!-- Issue #1515 — deadline reminders are on-device only (privacy.md §2.11). -->
        <exclude domain="file" path="deadline_reminders.json" />
    </device-transfer>
</data-extraction-rules>
