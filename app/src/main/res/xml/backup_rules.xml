<?xml version="1.0" encoding="utf-8"?>
<!--
  Pre-Android-12 (API < 31) auto-backup rules.

  Issue #951 — Exclude the EncryptedSharedPreferences file from auto-backup.
  The actual file name is `storyvox.secrets` (see
  DataModule.provideEncryptedPrefs). Prior versions of this file excluded
  `storyvox_secure_prefs`, a stale name that never matched anything — so
  encrypted blobs WERE being backed up to Google's cloud and restored on
  a fresh install. The new install's Android Keystore could not verify
  the MAC of the restored blob (its master key was generated fresh on
  the new install, while the blob was MAC'd with the old install's key),
  causing a hard crash on cold start:

      KeyStoreException: Signature/MAC verification failed
      (internal Keystore code: -30)

  This rule pairs with the defensive try/catch in
  DataModule.provideEncryptedPrefs (defense in depth).
-->
<full-backup-content>
    <exclude domain="sharedpref" path="storyvox.secrets.xml" />
    <exclude domain="sharedpref" path="storyvox.secrets" />
    <!-- #1514 — the encrypted document wallet (EncryptedFile blobs + the
         encrypted metadata manifest) must never be backed up. Same reason
         as the secrets prefs above: blobs are MAC'd with THIS install's
         Keystore master key, so a restored copy can't be verified — and
         it's the household's most sensitive data. On-device only. -->
    <exclude domain="file" path="wallet/" />
    <!-- Issue #1515 — deadline reminders are on-device only; never back
         them up to the cloud (privacy.md §2.11). -->
    <exclude domain="file" path="deadline_reminders.json" />
</full-backup-content>
